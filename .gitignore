scripts/.claude-preserve/

# local instance state — never commit
.secrets/
artifacts/

# daemon-owned benchmark power posture (rewritten hourly by
# com.thinkstack.tsbc-power.plist — tracking it guarantees a dirty tree)
benchmark/.tsbc-power.json
benchmark/.claude-bench-halt
# root scratch dir (server/scratch/ already ignored)
/scratch/

# work-product render candidates: generated media stays on disk, out of git.
# Text deliverables (md/txt/json) under work-products remain tracked.
# (Media committed before 2026-07-20 stays tracked; this governs new renders.)
work-products/**/*.mp4
work-products/**/*.png
work-products/**/*.jpg
work-products/**/*.jpeg
server/work-products/**/*.mp4
server/work-products/**/*.png
server/work-products/**/*.jpg
server/work-products/**/*.jpeg
